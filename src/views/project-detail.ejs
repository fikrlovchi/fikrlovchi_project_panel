<!doctype html>
<html lang="uz">
<head>
  <meta charset="utf-8" />
  <title><%= project.display_name %> — Fikrlovchi Panel</title>
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/topbar') %>
  <main>
    <p><a href="/">&larr; Loyihalar</a></p>
    <h2>
      <%= project.display_name %>
      <form method="post" action="/projects/<%= project.slug %>/rename" style="display:inline-flex;gap:4px;font-size:14px;vertical-align:middle;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="text" name="displayName" placeholder="yangi nom" style="font-size:12px;" />
        <button type="submit" style="font-size:12px;">Nomni o'zgartirish</button>
      </form>
    </h2>

    <% if (actionMessage) { %><p style="color:var(--success);">Bajarildi: <%= actionMessage %></p><% } %>
    <% if (errorMessage) { %><p class="error"><%= errorMessage %></p><% } %>

    <% if (isManaged) { %>
      <div class="card">
        <strong>Boshqaruv</strong>
        <div class="controls">
          <form method="post" action="/projects/<%= project.slug %>/interval">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="number" step="0.1" min="0" name="amount" value="<%= intervalInput.amount %>" placeholder="qiymat" required />
            <select name="unit">
              <option value="s" <%= intervalInput.unit === 's' ? 'selected' : '' %>>soniya</option>
              <option value="min" <%= intervalInput.unit === 'min' ? 'selected' : '' %>>daqiqa</option>
              <option value="h" <%= intervalInput.unit === 'h' ? 'selected' : '' %>>soat</option>
            </select>
            <button type="submit">Intervalni saqlash</button>
          </form>
          <form method="post" action="/projects/<%= project.slug %>/<%= project.is_paused ? 'resume' : 'pause' %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit"><%= project.is_paused ? 'Davom ettirish' : "To'xtatish" %></button>
          </form>
          <form method="post" action="/projects/<%= project.slug %>/run-now">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit">Hozir ishga tushirish</button>
          </form>
        </div>
        <% if (liveStatus && !liveStatus.error) { %>
          <div style="font-size:12px;color:var(--muted);">
            Service: <%= liveStatus.service.ActiveState %>/<%= liveStatus.service.SubState %> ·
            Timer: <%= liveStatus.timer.ActiveState %>/<%= liveStatus.timer.SubState %>
          </div>
        <% } else if (liveStatus && liveStatus.error) { %>
          <div class="error-banner">Holatni olishda xato: <%= liveStatus.error %></div>
        <% } %>
      </div>
    <% } %>

    <% if (canManageEnv) { %>
      <div class="card">
        <strong>Muhit sozlamalari</strong>
        <div class="muted-inline">Loyihaning `.env` fayliga yoziladigan qiymatlar — Telegram, tokenlar, Uzum va h.k.</div>

        <% if (envBindingRows.length > 0) { %>
          <table>
            <thead><tr><th>ENV kaliti</th><th>Manba</th><th></th></tr></thead>
            <tbody>
              <% envBindingRows.forEach(function (b) { %>
                <tr>
                  <td><code><%= b.env_key %></code></td>
                  <td><%= b.label %></td>
                  <td>
                    <form method="post" action="/projects/<%= project.slug %>/env-bindings/<%= b.id %>/delete">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <button type="submit" class="link-btn">o'chirish</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>

        <% if (envSourceGroups.length === 0) { %>
          <div class="muted-inline">Hali hech qanday katalog elementi yo'q. <a href="/variables">O'zgaruvchilar</a> sahifasida qo'shing.</div>
        <% } else { %>
          <form method="post" action="/projects/<%= project.slug %>/env-bindings" class="controls">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="text" id="envKeyInput" name="envKey" placeholder="ENV_KEY nomi (manba tanlansa avtomatik to'ladi)" required />
            <select id="envSourceSelect" name="source" required>
              <option value="">— Manba tanlang —</option>
              <% envSourceGroups.forEach(function (group) { %>
                <optgroup label="<%= group.label %>">
                  <% group.options.forEach(function (opt) { %>
                    <option value="<%= opt.value %>" data-envkey="<%= opt.envKey || '' %>"><%= opt.text %></option>
                  <% }); %>
                </optgroup>
              <% }); %>
            </select>
            <button type="submit">Bog'lash</button>
          </form>
          <div class="muted-inline">ENV kaliti manbadan avtomatik hosil bo'ladi; kerak bo'lsa qo'lda tahrirlashingiz mumkin.</div>
          <script>
            (function () {
              var sel = document.getElementById("envSourceSelect");
              var key = document.getElementById("envKeyInput");
              if (!sel || !key) return;
              sel.addEventListener("change", function () {
                var opt = sel.options[sel.selectedIndex];
                var suggested = opt ? opt.getAttribute("data-envkey") : "";
                if (!suggested) return;
                // Admin qo'lda yozgan qiymatni buzmaymiz: faqat bo'sh yoki
                // oldingi taklif turgan bo'lsa ustiga yozamiz.
                if (key.value === "" || key.value === key.dataset.suggested) {
                  key.value = suggested;
                  key.dataset.suggested = suggested;
                }
              });
            })();
          </script>
        <% } %>
      </div>
    <% } %>

    <div class="card">
      <strong>Google Sheets</strong>
      <% if (sheetLists.length === 0) { %>
        <div class="muted-inline">Hali sheet/list qo'shilmagan. <a href="/variables">O'zgaruvchilar</a> sahifasida qo'shing.</div>
      <% } else { %>
        <% var linkedListIds = currentSheetLinks.map(function (l) { return l.list_id; }); %>
        <form method="post" action="/projects/<%= project.slug %>/sheets" class="controls">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <select name="listIds" multiple size="<%= Math.min(6, sheetLists.length) %>" style="min-width:220px;">
            <% var lastSheetId = null; %>
            <% sheetLists.forEach(function (list) { %>
              <% if (list.sheet_id !== lastSheetId) { if (lastSheetId !== null) { %></optgroup><% } %>
                <optgroup label="<%= list.sheet.name %>">
              <% lastSheetId = list.sheet_id; } %>
              <option value="<%= list.id %>" <%= linkedListIds.indexOf(list.id) !== -1 ? 'selected' : '' %>><%= list.name %></option>
            <% }); %>
            <% if (lastSheetId !== null) { %></optgroup><% } %>
          </select>
          <button type="submit">Saqlash</button>
        </form>
        <div class="muted-inline">Faqat ko'rinish/hisobot uchun — .env fayliga yozilmaydi.</div>
      <% } %>
    </div>

    <div class="card">
      <strong>Ishga tushishlar tarixi</strong>
      <table>
        <thead>
          <tr><th>Boshlandi</th><th>Holat</th><th>Muvaffaqiyat</th><th>Xato</th><th>Xulosa</th></tr>
        </thead>
        <tbody>
        <% runs.forEach(function (r) { %>
          <tr>
            <td><%= formatTashkent(r.started_at) %></td>
            <td><span class="badge <%= r.status === 'success' ? 'ok' : 'error' %>"><%= r.status %></span></td>
            <td><%= r.success_count %></td>
            <td><%= r.error_count %></td>
            <td><%= r.summary || '' %></td>
          </tr>
          <% (logsByRun[r.id] || []).forEach(function (log) { %>
            <tr>
              <td class="log-line <%= log.level %>"><%= formatTashkent(log.logged_at) %></td>
              <td colspan="4" class="log-line <%= log.level %>">[<%= log.level %>] <%= log.message %></td>
            </tr>
          <% }); %>
        <% }); %>
        <% if (runs.length === 0) { %>
          <tr><td colspan="5">Hali hisobot kelmagan</td></tr>
        <% } %>
        </tbody>
      </table>
      <div class="pagination">
        <% if (page > 1) { %><a href="?page=<%= page - 1 %>">&larr; Oldingi</a><% } %>
        <span>Sahifa <%= page %> / <%= Math.max(1, Math.ceil(totalRuns / pageSize)) %></span>
        <% if (page * pageSize < totalRuns) { %><a href="?page=<%= page + 1 %>">Keyingi &rarr;</a><% } %>
      </div>
    </div>
  </main>
</body>
</html>
